# Twilio WhatsApp Sandbox — credentials
# 1. Get them from https://console.twilio.com → Account → API keys
# 2. Activate the Sandbox: console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 3. Send "join <your-keyword>" from the family phone to the Twilio Sandbox number
#    BEFORE the first alert — otherwise Twilio rejects it.

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# Имя того, кому звонят (попадёт в текст оповещения)
GUARD_CALL_VICTIM_NAME=אימא

# Номер члена семьи в формате E.164 (с "+")
GUARD_CALL_FAMILY_PHONE=+972537158722
